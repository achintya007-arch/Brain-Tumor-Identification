# Medical AI Diagnostics - Environment Configuration

# API Configuration
# Point to your local or remote medical AI backend API
NEXT_PUBLIC_API_URL=http://localhost:5000

# Backend should provide these endpoints:
# GET /health - Health check endpoint
# POST /predict - Image prediction endpoint
#   Request body: { image: "base64_encoded_image" }
#   Response: {
#     predictions: [{ label: string, probability: number }],
#     original_image: "base64_encoded_image",
#     gradcam_image: "base64_encoded_image",
#     inference_time_ms: number
#   }
